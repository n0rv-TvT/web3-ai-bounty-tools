{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/web3_report_result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["web3_result"],
  "properties": {
    "web3_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "command", "severity_mode", "status", "target", "summary", "finding_id", "source_pointer", "scope", "evidence_gate", "dupe_check", "evidence_missing", "report_sections_included", "next_action"],
      "properties": {
        "schema_version": {"const": "web3-ai-bounty/v1"},
        "command": {"const": "web3-report"},
        "severity_mode": {"$ref": "#/$defs/severity_mode"},
        "status": {"enum": ["REPORT_READY", "REPORT_BLOCKED"]},
        "target": {"type": "string"},
        "summary": {"type": "string"},
        "finding_id": {"type": "string"},
        "source_pointer": {"type": "string"},
        "scope": {"$ref": "#/$defs/scope_gate"},
        "evidence_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["exact_source", "vulnerable_code_path", "attacker_capability", "affected_asset", "exploit_sequence", "concrete_poc_assertion", "kill_condition", "scope_confirmation", "duplicate_intended_checked", "dupe_check_clear", "severity_rationale"],
          "properties": {
            "exact_source": {"type": "boolean"},
            "vulnerable_code_path": {"type": "boolean"},
            "attacker_capability": {"type": "boolean"},
            "affected_asset": {"type": "boolean"},
            "exploit_sequence": {"type": "boolean"},
            "concrete_poc_assertion": {"type": "boolean"},
            "kill_condition": {"type": "boolean"},
            "scope_confirmation": {"type": "boolean"},
            "duplicate_intended_checked": {"type": "boolean"},
            "dupe_check_clear": {"type": "boolean"},
            "severity_rationale": {"type": "boolean"}
          }
        },
        "dupe_check": {"$ref": "#/$defs/dupe_gate"},
        "evidence_missing": {"type": "array"},
        "report_sections_included": {"type": "array", "items": {"type": "string"}},
        "next_action": {"type": "string"}
      }
    }
  },
  "$defs": {
    "severity_mode": {"enum": ["critical-bounty", "medium-bounty", "audit-review", "learning"]},
    "scope_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "confidence", "affected_component_in_scope", "affected_asset_in_scope", "claimed_impact_accepted", "exclusions_apply", "testing_method_allowed"],
      "properties": {
        "artifact": {"type": "string"},
        "confidence": {"enum": ["confirmed", "partial", "unknown"]},
        "affected_component_in_scope": {"type": "boolean"},
        "affected_asset_in_scope": {"type": "boolean"},
        "claimed_impact_accepted": {"type": "boolean"},
        "exclusions_apply": {"type": "boolean"},
        "testing_method_allowed": {"type": "boolean"}
      }
    },
    "dupe_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_decision", "duplicate_of", "unresolved_reason"],
      "properties": {
        "review_decision": {"enum": ["CLEAR", "DUPLICATE", "INTENDED_BEHAVIOR", "KNOWN_RISK", "EXCLUDED", "NA_RISK", "NEEDS_CONTEXT"]},
        "duplicate_of": {"type": ["string", "null"]},
        "unresolved_reason": {"type": ["string", "null"]}
      }
    }
  }
}
