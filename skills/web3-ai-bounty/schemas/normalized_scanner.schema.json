{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencode.local/web3-ai-bounty/normalized_scanner.schema.json",
  "title": "Web3 Normalized Scanner Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "inputs", "normalizer", "summary", "leads", "suppressed"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "generated_at": { "$ref": "#/$defs/timestamp" },
    "inputs": { "type": "array", "items": { "$ref": "#/$defs/input" } },
    "normalizer": { "$ref": "#/$defs/normalizer" },
    "summary": { "$ref": "#/$defs/summary" },
    "leads": { "type": "array", "items": { "$ref": "#/$defs/lead" } },
    "suppressed": { "type": "array", "items": { "$ref": "#/$defs/lead" } }
  },
  "$defs": {
    "timestamp": { "type": "string", "format": "date-time" },
    "maybe_string": { "type": ["string", "null"] },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "tool", "raw_count"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "tool": { "type": "string" },
        "raw_count": { "type": "integer", "minimum": 0 }
      }
    },
    "normalizer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dedupe", "include_killed_in_leads", "code_index"],
      "properties": {
        "dedupe": { "type": "boolean" },
        "include_killed_in_leads": { "type": "boolean" },
        "code_index": { "$ref": "#/$defs/maybe_string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_count", "normalized_count", "lead_count", "chain_required_count", "killed_count", "by_status", "by_severity", "by_bug_class", "top_leads"],
      "properties": {
        "raw_count": { "type": "integer", "minimum": 0 },
        "normalized_count": { "type": "integer", "minimum": 0 },
        "lead_count": { "type": "integer", "minimum": 0 },
        "chain_required_count": { "type": "integer", "minimum": 0 },
        "killed_count": { "type": "integer", "minimum": 0 },
        "by_status": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "by_severity": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "by_bug_class": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "top_leads": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "status", "score", "bug_class", "location"],
            "properties": {
              "id": { "type": "string" },
              "status": { "type": "string" },
              "score": { "type": "integer" },
              "bug_class": { "type": "string" },
              "location": { "type": "string" }
            }
          }
        }
      }
    },
    "lead": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "tool", "tools", "input_path", "raw_index", "rule_id", "title", "bug_class", "category",
        "severity", "confidence", "status", "triage_verdict", "file", "line", "line_end", "contract", "function",
        "message", "impact_type", "impact_hint", "proof_needed", "proof_questions", "exploit_hypothesis",
        "dedupe_key", "group_key", "fingerprint", "tags", "code_context", "suppression", "score", "references", "cwe", "swc", "raw_excerpt"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^S-[a-fA-F0-9]{12}$" },
        "tool": { "type": "string" },
        "tools": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "input_path": { "type": "string" },
        "raw_index": { "type": "string" },
        "rule_id": { "type": "string" },
        "title": { "type": "string" },
        "bug_class": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string", "enum": ["UNKNOWN", "INFO", "LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "confidence": { "type": "string", "enum": ["UNKNOWN", "LOW", "MEDIUM", "HIGH", "CONFIRMED"] },
        "status": { "type": "string", "enum": ["LEAD", "CHAIN_REQUIRED", "KILL"] },
        "triage_verdict": { "type": "string", "enum": ["LEAD", "CHAIN_REQUIRED", "KILL"] },
        "file": { "$ref": "#/$defs/maybe_string" },
        "line": { "type": ["integer", "null"], "minimum": 1 },
        "line_end": { "type": ["integer", "null"], "minimum": 1 },
        "contract": { "$ref": "#/$defs/maybe_string" },
        "function": { "$ref": "#/$defs/maybe_string" },
        "message": { "type": "string" },
        "impact_type": { "type": "string", "enum": ["unknown", "stolen-funds", "frozen-funds", "bad-debt", "unauthorized-privileged-action", "account-takeover", "sensitive-data-exposure", "unsafe-signing-tool-execution", "governance-corruption", "other"] },
        "impact_hint": { "type": "string" },
        "proof_needed": { "type": "string" },
        "proof_questions": { "type": "array", "items": { "type": "string" } },
        "exploit_hypothesis": { "type": "string" },
        "dedupe_key": { "type": "string" },
        "group_key": { "type": "string" },
        "fingerprint": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "code_context": { "$ref": "#/$defs/code_context" },
        "suppression": { "type": ["object", "null"], "additionalProperties": false, "properties": { "reason": { "type": ["string", "null"] }, "kind": { "type": "string" } } },
        "score": { "$ref": "#/$defs/score" },
        "references": { "type": "array" },
        "cwe": {},
        "swc": {},
        "raw_excerpt": {},
        "merged_count": { "type": "integer", "minimum": 1 },
        "merged_fingerprints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "code_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract": { "type": "string" },
        "contract_kind": { "type": "string" },
        "contract_id": { "type": "string" },
        "bases": { "type": "array", "items": { "type": "string" } },
        "function": { "type": "string" },
        "function_id": { "type": "string" },
        "function_visibility": { "type": "string" },
        "state_mutability": { "type": "string" },
        "modifiers": { "type": "array", "items": { "type": "string" } },
        "auth_checks": { "type": "array", "items": { "type": "string" } },
        "value_moving": { "type": "boolean" },
        "asset_flow": {},
        "writes": { "type": "array", "items": { "type": "string" } },
        "reads": { "type": "array", "items": { "type": "string" } },
        "external_call_count": { "type": "integer", "minimum": 0 },
        "low_level_call_count": { "type": "integer", "minimum": 0 },
        "risk_tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["impact", "reachability", "poc_simplicity", "scope_match", "novelty", "economic_realism", "deductions", "total", "rationale"],
      "properties": {
        "impact": { "type": "integer", "minimum": 0, "maximum": 3 },
        "reachability": { "type": "integer", "minimum": 0, "maximum": 3 },
        "poc_simplicity": { "type": "integer", "minimum": 0, "maximum": 3 },
        "scope_match": { "type": "integer", "minimum": 0, "maximum": 3 },
        "novelty": { "type": "integer", "minimum": 0, "maximum": 3 },
        "economic_realism": { "type": "integer", "minimum": 0, "maximum": 3 },
        "deductions": { "type": "integer", "maximum": 0 },
        "total": { "type": "integer" },
        "rationale": { "type": "string" }
      }
    }
  }
}
